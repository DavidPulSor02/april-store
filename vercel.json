{
  "version": 2,
  "outputDirectory": "frontend-react/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/mobile/js/(.*)",
      "destination": "/mobile/js/$1"
    },
    {
      "source": "/mobile/css/(.*)",
      "destination": "/mobile/css/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
