{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/mobile/js/(.*)",
      "destination": "/frontend-react/dist/mobile/js/$1"
    },
    {
      "source": "/mobile/css/(.*)",
      "destination": "/frontend-react/dist/mobile/css/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend-react/dist/assets/$1"
    },
    {
      "source": "/mobile",
      "destination": "/frontend-react/dist/mobile/index.html"
    },
    {
      "source": "/mobile/(.*)",
      "destination": "/frontend-react/dist/mobile/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend-react/dist/index.html"
    }
  ]
}
