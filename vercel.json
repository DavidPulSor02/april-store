{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/mobile",
      "destination": "/frontend/mobile/index.html"
    },
    {
      "source": "/mobile/(.*)",
      "destination": "/frontend/mobile/index.html"
    },
    {
      "source": "/(.*).(js|css|png|jpg|jpeg|svg|ico)",
      "destination": "/frontend/$1.$2"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
